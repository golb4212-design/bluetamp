[Unit]
Description=BlueTamp node latency service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/bluetamp-nodes.env
ExecStart=/usr/bin/python3 /opt/bluetamp-nodes/bluetamp_nodes.py
Restart=on-failure
RestartSec=3
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadOnlyPaths=/var/lib/pasarguard /opt/pasarguard

[Install]
WantedBy=multi-user.target
